{
  "name": "@blackroad-os/agents",
  "version": "1.0.0",
  "description": "Autonomous agents and coordination logic for the BlackRoad system",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "author": "BlackRoad OS, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackRoad-OS/agents.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "build:worker": "tsup src/workers/agent-tasks.ts --format esm --clean --outDir dist/worker",
    "dev": "tsup src/index.ts --format esm --watch",
    "dev:worker": "wrangler dev",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prepare": "npm run build"
  },
  "dependencies": {
    "stripe": "17.5.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20250224.0",
    "@types/node": "20.17.19",
    "@typescript-eslint/eslint-plugin": "8.24.1",
    "@typescript-eslint/parser": "8.24.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-import": "2.31.0",
    "prettier": "3.5.2",
    "tsup": "8.4.0",
    "typescript": "5.7.3",
    "vitest": "3.0.6",
    "wrangler": "3.109.2",
    "@vitest/coverage-v8": "3.0.6"
  }
}
